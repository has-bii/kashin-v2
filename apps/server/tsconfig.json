{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    "skipLibCheck": true,

    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "baseUrl": ".",
    "paths": {
      "@server/*": ["src/*"],
      "@kashin/database/*": ["../../packages/database/src/*"],
      "@kashin/schema/*": ["../../packages/schema/src/*"],
    },
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"],
}
