{
  "name": "kashin-v2",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "bun run --filter @kashin/database db:generate",
    "db:migrate": "bun run --filter @kashin/database db:migrate",
    "db:deploy": "bun run --filter @kashin/database db:deploy"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
